
# Sail Config (should match docker-compose name for app container)
APP_SERVICE=student-project
APP_PORT=8000

APP_NAME=StudentProjectApi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_PORT=3306
DB_DATABASE=student-test-db

# Note - these are changes I made to .env, should the app not connect via student-test-user/password.
# (TablePlus wasn't really having a good time while i was trying to assign student-test-user privileges)
# DB_HOST=mysql
# DB_USERNAME=student-test-user
# DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_USERNAME=root
DB_PASSWORD=root

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
